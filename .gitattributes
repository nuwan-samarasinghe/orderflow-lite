# Force LF for all text files
* text=auto eol=lf

# Explicit file types
*.java text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.properties text eol=lf

*.ts   text eol=lf
*.js   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.scss text eol=lf

*.json text eol=lf
*.md   text eol=lf

# Shell scripts must be LF
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary